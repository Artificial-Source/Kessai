# Discord Bot Configuration
# Copy this file to .env and fill in your values
# See packages/discord-bot/README.md for setup instructions

# ============================================================
# REQUIRED
# ============================================================

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your Discord user ID (enable Developer Mode in Discord Settings → Advanced,
# then right-click your username → Copy User ID)
DISCORD_USER_ID=your_discord_user_id_here

# ============================================================
# OPTIONAL
# ============================================================

# Discord channel ID to send reminders to.
# If not set, reminders are sent as DMs to DISCORD_USER_ID.
# Right-click a channel in Discord → Copy Channel ID (requires Developer Mode).
# DISCORD_CHANNEL_ID=your_channel_id_here

# Absolute path to the Subby backup JSON file exported from the app.
# Defaults to the OS-specific Subby app data directory:
#   Linux:   ~/.local/share/subby/subby-backup.json
#   macOS:   ~/Library/Application Support/subby/subby-backup.json
#   Windows: %APPDATA%/subby/subby-backup.json
# SUBBY_BACKUP_PATH=/home/youruser/.local/share/subby/subby-backup.json

# Time to send daily payment reminders in 24-hour HH:MM format.
# Default: 09:00
# REMINDER_TIME=09:00

# IANA timezone identifier for the reminder cron schedule.
# Default: UTC
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones for valid values.
# TIMEZONE=America/New_York
