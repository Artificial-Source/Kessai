{
  "name": "@subby/discord-bot",
  "version": "0.1.0",
  "description": "Discord bot for Subby subscription reminders",
  "author": "ASF",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ASF/Subby.git"
  },
  "homepage": "https://github.com/ASF/Subby/tree/main/packages/discord-bot",
  "bugs": {
    "url": "https://github.com/ASF/Subby/issues"
  },
  "keywords": [
    "discord",
    "bot",
    "subby",
    "reminders",
    "subscriptions"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "subby-bot": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.cjs --format=cjs --external:@discordjs/opus --external:bufferutil --external:utf-8-validate --external:zlib-sync",
    "build:exe": "pnpm build:bundle && pkg dist/bundle.cjs --target node18-linux-x64 --output dist/subby-bot-linux",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "pkg": {
    "assets": [],
    "targets": [
      "node18-linux-x64"
    ]
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dayjs": "^1.11.19",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.24.2",
    "pkg": "^5.8.1",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3"
  }
}
